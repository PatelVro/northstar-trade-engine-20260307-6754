{
  "traders": [
    {
      "id": "ibkr_paper_trader",
      "name": "Northstar IBKR Paper",
      "enabled": true,
      "ai_model": "deepseek",
      "exchange": "ibkr",
      "data_provider": "ibkr",
      "broker": "ibkr",
      "ibkr_gateway_url": "https://127.0.0.1:5002/v1/api",
      "ibkr_account_id": "${NORTHSTAR_IBKR_ACCOUNT_ID}",
      "mode": "paper",
      "instrument_type": "equity",
      "order_sizing_mode": "notional",
      "trusted_symbols_file": "data/universe/us_canada_tradable_core.txt",
      "strategy_mode": "momentum_fallback",
