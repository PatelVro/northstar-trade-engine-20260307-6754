{
  "traders": [
    {
      "id": "hyperliquid_deepseek",
      "name": "Northstar Hyperliquid",
      "enabled": true,
      "ai_model": "deepseek",
      "exchange": "hyperliquid",
      "hyperliquid_private_key": "${NORTHSTAR_HYPERLIQUID_PRIVATE_KEY}",
      "hyperliquid_wallet_addr": "${NORTHSTAR_HYPERLIQUID_WALLET_ADDR}",
      "hyperliquid_testnet": false,
      "deepseek_key": "${NORTHSTAR_DEEPSEEK_API_KEY}",
      "initial_balance": 1000,
      "scan_interval_minutes": 3
    },
    {
      "id": "binance_qwen",
      "name": "Northstar Binance Qwen",
      "enabled": true,
      "ai_model": "qwen",
      "exchange": "binance",
      "binance_api_key": "${NORTHSTAR_BINANCE_API_KEY}",
      "binance_secret_key": "${NORTHSTAR_BINANCE_SECRET_KEY}",
      "qwen_key": "${NORTHSTAR_QWEN_API_KEY}",
      "initial_balance": 1000,
      "scan_interval_minutes": 3
    },
    {
      "id": "binance_custom",
      "name": "Northstar Custom API",
      "enabled": false,
      "ai_model": "custom",
      "exchange": "binance",
      "binance_api_key": "${NORTHSTAR_BINANCE_API_KEY}",
      "binance_secret_key": "${NORTHSTAR_BINANCE_SECRET_KEY}",
      "custom_api_url": "${NORTHSTAR_CUSTOM_API_URL}",
      "custom_api_key": "${NORTHSTAR_CUSTOM_API_KEY}",
      "custom_model_name": "${NORTHSTAR_CUSTOM_MODEL_NAME}",
      "initial_balance": 1000,
      "scan_interval_minutes": 3
    },
    {
      "id": "aster_deepseek",
      "name": "Northstar Aster",
      "enabled": true,
      "ai_model": "deepseek",
      "exchange": "aster",
      "aster_user": "${NORTHSTAR_ASTER_USER}",
      "aster_signer": "${NORTHSTAR_ASTER_SIGNER}",
      "aster_private_key": "${NORTHSTAR_ASTER_PRIVATE_KEY}",
      "deepseek_key": "${NORTHSTAR_DEEPSEEK_API_KEY}",
      "initial_balance": 1000.0,
      "scan_interval_minutes": 3
    }
  ],
  "leverage": {
    "btc_eth_leverage": 5,
    "altcoin_leverage": 5
  },
  "use_default_coins": true,
  "default_coins": [
    "BTCUSDT",
    "ETHUSDT",
    "SOLUSDT",
    "BNBUSDT",
    "XRPUSDT",
    "DOGEUSDT",
    "ADAUSDT",
    "HYPEUSDT"
  ],
  "coin_pool_api_url": "",
  "oi_top_api_url": "",
  "api_server_port": 8080,
  "max_daily_loss": 10.0,
  "max_drawdown": 20.0,
  "stop_trading_minutes": 60
}
