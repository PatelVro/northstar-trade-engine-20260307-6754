# Northstar environment template
# Copy this file to .env.local or export the variables in your shell before starting Northstar.

# Ports
NORTHSTAR_BACKEND_PORT=8080
NORTHSTAR_FRONTEND_PORT=3000
NORTHSTAR_TIMEZONE=America/Toronto

# Optional build metadata for Docker or scripted release builds
NORTHSTAR_VERSION=dev
NORTHSTAR_COMMIT=
NORTHSTAR_BUILD_TIME=
NORTHSTAR_BUILD_CHANNEL=local
NORTHSTAR_BUILD_DIRTY=

# AI providers
NORTHSTAR_DEEPSEEK_API_KEY=
NORTHSTAR_QWEN_API_KEY=
NORTHSTAR_CUSTOM_API_URL=
NORTHSTAR_CUSTOM_API_KEY=
NORTHSTAR_CUSTOM_MODEL_NAME=

# IBKR
NORTHSTAR_IBKR_BASE_URL=https://127.0.0.1:5002/v1/api
NORTHSTAR_IBKR_ACCOUNT_ID=
NORTHSTAR_IBKR_SESSION_COOKIE=

# Alpaca
NORTHSTAR_ALPACA_API_KEY=
NORTHSTAR_ALPACA_SECRET_KEY=

# Binance
NORTHSTAR_BINANCE_API_KEY=
NORTHSTAR_BINANCE_SECRET_KEY=

# Hyperliquid
NORTHSTAR_HYPERLIQUID_PRIVATE_KEY=
NORTHSTAR_HYPERLIQUID_WALLET_ADDR=

# Aster
NORTHSTAR_ASTER_USER=
NORTHSTAR_ASTER_SIGNER=
NORTHSTAR_ASTER_PRIVATE_KEY=
